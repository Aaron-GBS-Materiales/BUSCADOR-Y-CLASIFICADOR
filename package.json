<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clasificador UNSPSC — Base Precargada</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap');

  :root {
    --bg:        #0c0e14;
    --surface:   #151823;
    --surface2:  #1d2130;
    --surface3:  #252a3d;
    --border:    #2c3148;
    --accent:    #4f7cff;
    --accent-soft: rgba(79,124,255,.12);
    --teal:      #2dd4bf;
    --success:   #22c55e;
    --warning:   #f59e0b;
    --danger:    #ef4444;
    --text:      #e9ebf2;
    --text-dim:  #9aa1b5;
    --text-mute: #5d6477;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Inter', sans-serif;
  }

  *,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }

  body { font-family:var(--sans); background:var(--bg); color:var(--text); min-height:100vh; }

  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 16px 28px;
    display: flex; align-items: center; gap: 14px;
    position: sticky; top: 0; z-index: 100;
  }
  .logo {
    width:42px; height:42px;
    background: linear-gradient(135deg, var(--accent), var(--teal));
    border-radius:11px;
    display:flex; align-items:center; justify-content:center;
    font-weight:800; font-size:17px; color:#fff; flex-shrink:0;
  }
  .header-title h1 { font-size:16px; font-weight:700; letter-spacing:-.3px; }
  .header-title p  { font-size:11.5px; color:var(--text-mute); margin-top:2px; }

  .db-status {
    margin-left:auto;
    display:flex; align-items:center; gap:8px;
    background: var(--surface2);
    border: 1px solid rgba(34,197,94,.3);
    padding: 7px 14px; border-radius: 20px;
    font-size: 12px; color: var(--text);
  }
  .db-status .dot { width:8px; height:8px; border-radius:50%; background:var(--success); box-shadow:0 0 8px rgba(34,197,94,.6); }
  .db-status b { color: var(--teal); font-family: var(--mono); }

  .app { max-width: 1280px; margin: 0 auto; padding: 24px 28px 60px; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 24px;
    margin-bottom: 20px;
  }
  .card-head { display:flex; align-items:center; gap:12px; margin-bottom:16px; }
  .step-num {
    width:26px; height:26px;
    background: var(--accent-soft); color: var(--accent);
    border-radius:7px;
    display:flex; align-items:center; justify-content:center;
    font-size:13px; font-weight:700; flex-shrink:0;
  }
  .card-head h2 { font-size:14.5px; font-weight:600; }

  .tabs {
    display:flex; gap:4px;
    background:var(--surface); border:1px solid var(--border);
    border-radius:11px; padding:4px;
    width:fit-content; margin-bottom:20px;
  }
  .tab {
    background:none; border:none; color:var(--text-dim);
    padding:9px 22px; border-radius:8px;
    font-size:13px; font-weight:600; cursor:pointer;
    font-family:var(--sans); transition:all .2s;
  }
  .tab.active { background:var(--accent); color:#fff; }
  .tab:not(.active):hover { color:var(--text); }

  .panel { display:none; }
  .panel.active { display:block; }

  .search-row { display:flex; gap:10px; }
  .search-input {
    flex:1;
    background:var(--surface2); border:1px solid var(--border);
    border-radius:10px; padding:13px 16px;
    color:var(--text); font-family:var(--mono); font-size:13.5px;
    outline:none; transition:border-color .2s; text-transform:uppercase;
  }
  .search-input:focus { border-color:var(--accent); }
  .search-input::placeholder { color:var(--text-mute); text-transform:none; font-family:var(--sans); }

  .btn {
    background: linear-gradient(135deg, var(--accent), #6366f1);
    color:#fff; border:none; border-radius:10px;
    padding:13px 26px; font-size:13.5px; font-weight:600;
    font-family:var(--sans); cursor:pointer;
    display:flex; align-items:center; gap:8px;
    transition:opacity .2s, transform .1s; white-space:nowrap;
  }
  .btn:hover:not(:disabled){ opacity:.9; }
  .btn:active:not(:disabled){ transform:scale(.98); }
  .btn:disabled { opacity:.4; cursor:not-allowed; }
  .btn.ghost { background:var(--surface2); border:1px solid var(--border); color:var(--text-dim); }
  .btn.ghost:hover { border-color:var(--accent); color:var(--text); }
  .btn.success-btn { background: linear-gradient(135deg, var(--success), var(--teal)); }

  .single-result { margin-top:20px; }
  .match-card {
    background:var(--surface2); border:1px solid var(--border);
    border-radius:12px; padding:18px 20px; margin-bottom:12px;
    display:flex; gap:18px; align-items:flex-start;
  }
  .match-card.top { border-color:rgba(79,124,255,.5); background:linear-gradient(135deg, rgba(79,124,255,.07), var(--surface2)); }
  .match-rank {
    width:34px; height:34px; border-radius:9px;
    background:var(--surface3);
    display:flex; align-items:center; justify-content:center;
    font-weight:700; font-size:14px; color:var(--text-dim); flex-shrink:0;
  }
  .match-card.top .match-rank { background:var(--accent); color:#fff; }
  .match-body { flex:1; min-width:0; }
  .match-code { font-family:var(--mono); font-size:17px; font-weight:600; color:var(--accent); letter-spacing:.5px; }
  .match-desc { font-size:13.5px; margin-top:4px; }
  .match-hier { font-size:11px; color:var(--text-mute); margin-top:4px; }
  .match-reason { font-size:12px; color:var(--text-mute); margin-top:6px; line-height:1.5; }

  .conf {
    padding:4px 12px; border-radius:6px;
    font-size:11px; font-weight:700; letter-spacing:.8px; flex-shrink:0;
  }
  .conf.ALTA  { background:rgba(34,197,94,.12);  color:var(--success); border:1px solid rgba(34,197,94,.3); }
  .conf.MEDIA { background:rgba(245,158,11,.12); color:var(--warning); border:1px solid rgba(245,158,11,.3); }
  .conf.BAJA  { background:rgba(239,68,68,.12);  color:var(--danger);  border:1px solid rgba(239,68,68,.3); }

  .bulk-grid { display:grid; grid-template-columns:1fr 280px; gap:16px; }
  .bulk-textarea {
    width:100%; min-height:200px;
    background:var(--surface2); border:1px solid var(--border);
    border-radius:10px; padding:14px;
    color:var(--text); font-family:var(--mono); font-size:12.5px; line-height:1.7;
    resize:vertical; outline:none; transition:border-color .2s;
  }
  .bulk-textarea:focus { border-color:var(--accent); }
  .bulk-textarea::placeholder { color:var(--text-mute); }

  .bulk-side { display:flex; flex-direction:column; gap:12px; }
  .dz {
    border:2px dashed var(--border); border-radius:11px;
    padding:20px 14px; text-align:center; cursor:pointer;
    position:relative; transition:all .2s;
  }
  .dz:hover, .dz.over { border-color:var(--accent); background:var(--accent-soft); }
  .dz input { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; }
  .dz-title { font-size:13px; font-weight:600; margin-top:6px; }
  .dz-sub { font-size:11px; color:var(--text-mute); margin-top:4px; }
  .dz-icon { font-size:26px; }
  .hint {
    background:var(--surface2); border-left:3px solid var(--teal);
    border-radius:8px; padding:11px 14px;
    font-size:11.5px; color:var(--text-dim); line-height:1.6;
  }
  .hint code { color:var(--teal); font-family:var(--mono); font-size:11px; }

  .progress-box {
    display:none;
    background:var(--surface2); border:1px solid var(--border);
    border-radius:12px; padding:18px 22px; margin-top:18px;
  }
  .progress-box.show { display:block; }
  .progress-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; font-size:13px; }
  .progress-count { font-family:var(--mono); color:var(--teal); font-weight:600; }
  .progress-track { height:8px; background:var(--surface3); border-radius:4px; overflow:hidden; }
  .progress-fill {
    height:100%; width:0%;
    background:linear-gradient(90deg, var(--accent), var(--teal));
    border-radius:4px; transition:width .35s ease;
  }
  .progress-detail { font-size:11.5px; color:var(--text-mute); margin-top:10px; font-family:var(--mono); }

  .results-card { display:none; }
  .results-card.show { display:block; }
  .results-toolbar { display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
  .results-count { font-size:13px; color:var(--text-dim); margin-right:auto; }
  .results-count b { color:var(--text); }

  .table-scroll { overflow-x:auto; border:1px solid var(--border); border-radius:11px; }
  table { width:100%; border-collapse:collapse; font-size:12.5px; min-width:900px; }
  thead { background:var(--surface2); }
  th {
    text-align:left; padding:11px 14px;
    font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase;
    color:var(--text-mute); border-bottom:1px solid var(--border); white-space:nowrap;
  }
  td { padding:11px 14px; border-bottom:1px solid rgba(44,49,72,.5); vertical-align:top; line-height:1.5; }
  tbody tr:last-child td { border-bottom:none; }
  tbody tr:hover td { background:rgba(79,124,255,.04); }

  .td-sap  { font-family:var(--mono); font-size:12px; color:var(--text-mute); white-space:nowrap; }
  .td-den  { font-weight:500; max-width:260px; }
  .td-code { font-family:var(--mono); font-weight:600; color:var(--accent); white-space:nowrap; font-size:13px; }
  .td-desc { color:var(--text-dim); }
  .td-alt  { font-family:var(--mono); font-size:11px; color:var(--text-mute); line-height:1.8; white-space:nowrap; }
  .td-alt span { display:block; }
  .td-alt b { color:var(--text-dim); font-weight:500; }
  .no-sap { color:var(--text-mute); font-style:italic; font-size:11px; }
  .err-cell { color:var(--danger); font-size:11.5px; }

  .toast {
    position:fixed; bottom:24px; right:24px;
    background:var(--surface2); border:1px solid var(--border);
    border-radius:10px; padding:13px 18px; font-size:13px;
    box-shadow:0 10px 40px rgba(0,0,0,.5);
    transform:translateY(90px); opacity:0; transition:all .3s;
    z-index:999; max-width:380px;
  }
  .toast.show { transform:translateY(0); opacity:1; }
  .toast.ok  { border-color:rgba(34,197,94,.45); }
  .toast.err { border-color:rgba(239,68,68,.45); }
  .toast.warn{ border-color:rgba(245,158,11,.45); }

  .spinner {
    width:15px; height:15px;
    border:2px solid rgba(255,255,255,.3); border-top-color:#fff;
    border-radius:50%; animation:spin .7s linear infinite; display:inline-block;
  }
  @keyframes spin { to { transform:rotate(360deg); } }

  ::-webkit-scrollbar { width:6px; height:8px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }
  ::-webkit-scrollbar-thumb:hover { background:var(--accent); }

  /* Engine selector */
  .engine-row {
    display:flex; align-items:center; gap:10px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 12px 20px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .engine-label { font-size:12px; font-weight:600; color:var(--text-dim); }
  .engine-toggle {
    display:flex; gap:4px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 3px;
  }
  .engine-opt {
    background:none; border:none;
    color: var(--text-dim);
    padding: 7px 16px;
    border-radius: 7px;
    font-size: 12px; font-weight:600;
    cursor:pointer; font-family:var(--sans);
    transition: all .2s;
    display:flex; align-items:center; gap:6px;
  }
  .engine-opt.active { background: var(--teal); color: #0c0e14; }
  .engine-opt:not(.active):hover { color: var(--text); }
  .engine-desc { font-size:11px; color:var(--text-mute); margin-left:auto; }

  /* API key panel */
  .api-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px 20px;
    margin-bottom: 20px;
    display:flex; align-items:center; gap:12px; flex-wrap:wrap;
  }
  .api-card.ok { border-color: rgba(34,197,94,.35); }
  .api-card .api-label { font-size:12px; font-weight:600; color:var(--text-dim); white-space:nowrap; display:flex; align-items:center; gap:8px; }
  .api-input {
    flex:1; min-width: 220px;
    background:var(--surface2); border:1px solid var(--border);
    border-radius:8px; padding:10px 12px;
    color:var(--text); font-family:var(--mono); font-size:12px;
    outline:none; transition:border-color .2s;
  }
  .api-input:focus { border-color:var(--accent); }
  .api-note { width:100%; font-size:11px; color:var(--text-mute); line-height:1.5; }
  .api-note a { color: var(--teal); }
  .api-status-pill {
    font-size:11px; font-weight:700; padding:4px 10px; border-radius:12px;
    background: rgba(239,68,68,.12); color: var(--danger); border:1px solid rgba(239,68,68,.3);
    white-space:nowrap;
  }
  .api-status-pill.ok { background: rgba(34,197,94,.12); color: var(--success); border-color: rgba(34,197,94,.3); }

  @media (max-width:860px) {
    .bulk-grid { grid-template-columns:1fr; }
    .app { padding:16px 14px 50px; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">U⁘</div>
  <div class="header-title">
    <h1>Clasificador UNSPSC</h1>
    <p>Base precargada · Catalogación industrial con interpretación semántica</p>
  </div>
  <div class="db-status">
    <span class="dot"></span>
    <span id="dbStatusText">Cargando base…</span>
  </div>
</header>

<div class="app">

  <!-- ═══ SELECTOR DE MOTOR ═══ -->
  <div class="engine-row">
    <span class="engine-label">Motor de clasificación:</span>
    <div class="engine-toggle">
      <button class="engine-opt active" id="engineLocal" onclick="setEngine('local')">⚡ Local · Gratis</button>
      <button class="engine-opt" id="engineIA" onclick="setEngine('ia')">🧠 IA Claude · Requiere API key</button>
    </div>
    <span class="engine-desc" id="engineDesc">Sin costo · sin internet · resultados instantáneos por similitud semántica con sinónimos</span>
  </div>

  <!-- ═══ CONFIGURACIÓN API ═══ -->
  <div class="api-card" id="apiCard" style="display:none;">
    <span class="api-label">🔑 API Key de Anthropic</span>
    <input type="password" class="api-input" id="apiKeyInput" placeholder="sk-ant-api03-..." autocomplete="off">
    <button class="btn ghost" style="padding:10px 16px;" onclick="saveApiKey()">Guardar</button>
    <span class="api-status-pill" id="apiStatusPill">Sin configurar</span>
    <div class="api-note">
      Necesaria para el motor de clasificación semántica. Se guarda únicamente en este navegador (localStorage), nunca se envía a otro servidor que no sea api.anthropic.com.
      Obtén tu clave en <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener">console.anthropic.com</a>.
    </div>
  </div>

  <!-- ═══ TABS ═══ -->
  <div class="tabs">
    <button class="tab active" data-panel="panelSingle">🔍 Consulta Individual</button>
    <button class="tab" data-panel="panelBulk">📦 Consulta Masiva</button>
  </div>

  <!-- ═══ PANEL: INDIVIDUAL ═══ -->
  <div class="panel active" id="panelSingle">
    <div class="card">
      <div class="card-head">
        <div class="step-num">1</div>
        <h2>Ingresa la denominación del material</h2>
      </div>
      <div class="search-row">
        <input class="search-input" id="singleInput"
               placeholder='Ej: VALVULA CHECK 4" ACERO INOX · FLEXIBLE HIDRAULICO 1" · RODAJE 6312'
               onkeydown="if(event.key==='Enter')searchSingle()">
        <button class="btn" id="btnSingle" onclick="searchSingle()">
          <span id="btnSingleIcon">🔍</span> BUSCAR
        </button>
      </div>
      <div class="single-result" id="singleResult"></div>
    </div>
  </div>

  <!-- ═══ PANEL: MASIVO ═══ -->
  <div class="panel" id="panelBulk">
    <div class="card">
      <div class="card-head">
        <div class="step-num">1</div>
        <h2>Pega o carga los materiales a clasificar</h2>
      </div>

      <div class="bulk-grid">
        <textarea class="bulk-textarea" id="bulkInput"
placeholder="Pega desde Excel (CODIGO SAP [TAB] DENOMINACION):

30001234	VALVULA CHECK 4&quot; ACERO INOX
30004567	RODAMIENTO 6312
	MANGUERA HIDRAULICA 1&quot; SAE100R2

(la columna SAP puede ir vacía para materiales nuevos)"></textarea>

        <div class="bulk-side">
          <div class="dz" id="dzBulk">
            <input type="file" id="fileBulk" accept=".xlsx,.xls,.csv,.tsv,.txt">
            <div class="dz-icon">📄</div>
            <div class="dz-title">O carga un archivo Excel</div>
            <div class="dz-sub">Columna A: SAP · Columna B: Denominación</div>
          </div>
          <div class="hint">
            <b>Formato esperado</b><br>
            <code>CODIGO SAP ⇥ DENOMINACION</code><br>
            Una fila por material. Si no tiene código SAP, deja la primera columna vacía.
          </div>
        </div>
      </div>

      <div style="display:flex; gap:10px; margin-top:16px;">
        <button class="btn" id="btnBulk" onclick="processBulk()">
          <span id="btnBulkIcon">⚡</span> CLASIFICAR TODO
        </button>
        <button class="btn ghost" onclick="clearBulk()">Limpiar</button>
      </div>

      <div class="progress-box" id="progressBox">
        <div class="progress-head">
          <span>Procesando materiales…</span>
          <span class="progress-count" id="progressCount">0 / 0</span>
        </div>
        <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
        <div class="progress-detail" id="progressDetail"></div>
      </div>
    </div>

    <div class="card results-card" id="resultsCard">
      <div class="results-toolbar">
        <span class="results-count" id="resultsCount"></span>
        <button class="btn ghost" onclick="copyTSV()">📋 Copiar para Excel</button>
        <button class="btn success-btn" onclick="exportXLSX()">⬇ EXPORTAR EXCEL</button>
      </div>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Código SAP</th>
              <th>Denominación</th>
              <th>Código UNSPSC</th>
              <th>Descripción UNSPSC</th>
              <th>Confianza</th>
              <th>Alternativas</th>
            </tr>
          </thead>
          <tbody id="resultsBody"></tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>
/* ═══════════════════════════════════════════════════════════════════════════
   BASE UNSPSC PRECARGADA (incrustada en el archivo)
   Estructura: c = ["NOMBRE CLASE|NOMBRE FAMILIA", ...]
               p = ["CODIGO|NOMBRE PRODUCTO|claseIdx", ...]
═══════════════════════════════════════════════════════════════════════════ */
