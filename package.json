const STOPWORDS = new Set(['DE','DEL','LA','EL','LOS','LAS','PARA','CON','POR','EN','UN','UNA','Y','O','A','AL','SIN','SUS','SU','QUE','SE']);

function normalize(s) {
  return String(s).toUpperCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^A-Z0-9\s]/g, ' ')
    .replace(/\s+/g, ' ').trim();
}

function tokenize(s) {
  const tokens = normalize(s).split(' ').filter(t => t.length > 1 && !STOPWORDS.has(t) && isNaN(t));
  const expanded = new Set(tokens);
  
  // Descomponer palabras compuestas conocidas
  const compounds = {
    'MOTOREDUCTOR': ['MOTOR','REDUCTOR'],
    'MOTORREDUCTOR': ['MOTOR','REDUCTOR'],
    'MOTOVARIADOR': ['MOTOR','VARIADOR'],
    'BOMBAHIDRAULICA': ['BOMBA','HIDRAULICA'],
    'ELECTRODOMESTICO': ['ELECTRO','DOMESTICO'],
    'PORTAMINAS': ['LAPIZ','MINAS'],
    'SACAPUNTAS': ['LAPIZ','PUNTA'],
    'PORTAPAPELES': ['PAPEL','PORTA'],
  };
  for (const t of tokens) {
    if (compounds[t]) {
      for (const part of compounds[t]) {
        if (part.length > 2) expanded.add(part);
      }
    }
    // Si es palabra larga (>10 chars), intentar dividirla buscando patrones comunes
    if (t.length > 10) {
      for (const p of ['MOTOR','REDUCTOR','BOMBA','HIDRAULICA','ELECTRO','AIRE','AGUA','GAS']) {
        if (t.includes(p) && !expanded.has(p)) expanded.add(p);
      }
    }
  }
  
  return expanded;
}

function stem(t) {
  // raíz simple para singular/plural español
  if (t.length > 4 && t.endsWith('ES')) return t.slice(0, -2);
  if (t.length > 3 && t.endsWith('S'))  return t.slice(0, -1);
  return t;
}

/* ═══════════════════════════════════════════════════════════════════════════
   PRE-FILTRO: REVISIÓN TOTAL DE LA BASE
   Fase 1: índice invertido (tokens exactos + sinónimos + raíces)
   Fase 2: barrido completo por subcadenas si la fase 1 es débil
═══════════════════════════════════════════════════════════════════════════ */
function getCandidates(denominacion, maxCandidates = 50) {
  const baseTokens = [...tokenize(denominacion)];
  const scores = new Map();

  const addScore = (idx, w) => scores.set(idx, (scores.get(idx) || 0) + w);

  // ── Fase 1: índice invertido ──
  const queryVariants = new Map(); // token -> peso
  for (const t of baseTokens) {
    queryVariants.set(t, 4);
    const st = stem(t);
    if (st !== t) queryVariants.set(st, 3);
    queryVariants.set(t + 'S', 3);
    queryVariants.set(t + 'ES', 3);
    if (SYNONYMS[t]) for (const s of SYNONYMS[t]) {
      if (!queryVariants.has(s)) queryVariants.set(s, 2.5);
      const ss = stem(s);
      if (!queryVariants.has(ss)) queryVariants.set(ss, 2);
    }
    if (SYNONYMS[st] && st !== t) for (const s of SYNONYMS[st]) {
      if (!queryVariants.has(s)) queryVariants.set(s, 2.5);
    }
  }

  for (const [tok, w] of queryVariants) {
    if (unspscIndex[tok]) {
      for (const idx of unspscIndex[tok]) addScore(idx, w);
    }
  }

  // ── Fase 2: barrido total por subcadena (revisión completa de la base) ──
  // Se ejecuta siempre con las raíces principales para no perder coincidencias
  // que el índice por token exacto no capture (palabras compuestas, variantes).
  const mainStems = baseTokens.map(stem).filter(t => t.length >= 4);
  if (mainStems.length > 0) {
    const needBoost = scores.size < maxCandidates * 2;
    for (let idx = 0; idx < unspscDB.length; idx++) {
      const hay = unspscDB[idx].desc + ' ' + unspscDB[idx].clase;
      let hits = 0;
      for (const st of mainStems) {
        if (hay.includes(st)) hits++;
      }
      if (hits > 0) {
        // peso menor que el índice exacto; mayor si el índice encontró poco
        addScore(idx, hits * (needBoost ? 1.5 : 0.5));
      }
    }
  }

  let ranked = [...scores.entries()].sort((a, b) => b[1] - a[1]);

  // Bonus: priorizar registros cuyo primer token coincide con el sustantivo principal
  const firstToken = stem(baseTokens[0] || '');
  if (firstToken) {
    ranked = ranked.map(([idx, sc]) => {
      const firstDescTok = stem(normalize(unspscDB[idx].desc).split(' ')[0] || '');
      return [idx, firstDescTok === firstToken ? sc + 3 : sc];
    }).sort((a, b) => b[1] - a[1]);
  }

  let candidates = ranked.slice(0, maxCandidates).map(([idx]) => unspscDB[idx]);

  if (candidates.length === 0) {
    // Último recurso: muestra para que la IA decida (no debería ocurrir con el barrido total)
    candidates = unspscDB.slice(0, 100);
  }
  return candidates;
}

