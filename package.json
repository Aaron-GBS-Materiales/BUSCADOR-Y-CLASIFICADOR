/* ═══════════════════════════════════════════════════════════════════════════
   CLASIFICADOR LOCAL (sin API, sin costo)
   Usa el índice completo + sinónimos + ponderación por rareza de término (IDF)
═══════════════════════════════════════════════════════════════════════════ */
// ¿Comparten raíz dos tokens? Robusto para plurales españoles
// (GUANTE/GUANTES, MOTOR/MOTORES, VALVULA/VALVULAS)
function sameRoot(a, b) {
  if (a === b) return true;
  if (a.length < 4 || b.length < 4) return false;
  const [short_, long_] = a.length <= b.length ? [a, b] : [b, a];
  return long_.startsWith(short_) && (long_.length - short_.length) <= 2;
}

function localClassify(denominacion) {
  const baseTokens = [...tokenize(denominacion)];
  if (baseTokens.length === 0) return [];

  const N = unspscDB.length;
  const scores = new Map();
  const matchInfo = new Map(); // idx -> Set de tokens base cubiertos

  // IDF: términos raros valen más que términos comunes
  // Pero un término que aparece en >30% de registros es casi ruido
  const idf = tok => {
    const df = unspscIndex[tok] ? unspscIndex[tok].length : 0;
    if (df === 0) return 0;
    const commonness = df / N;
    if (commonness > 0.3) return 0.2; // muy común: casi no suma
    if (commonness > 0.15) return 0.4; // común: poco peso
    return 1 + Math.log(N / df); // raro: peso normal
  };

  for (const t of baseTokens) {
    const st = stem(t);
    // Inflexiones de la MISMA palabra: comparten un único IDF combinado
    // (evita que el singular raro pese más que el plural común)
    const inflections = new Set([t, st, t + 'S', t + 'ES', st + 'S', st + 'ES']);
    let dfGroup = 0;
    for (const v of inflections) dfGroup += unspscIndex[v] ? unspscIndex[v].length : 0;
    const idfGroup = dfGroup > 0 ? 1 + Math.log(N / dfGroup) : 0;

    const variants = new Map(); // variante -> peso efectivo (ya incluye IDF)
    for (const v of inflections) {
      if (unspscIndex[v]) variants.set(v, 4 * idfGroup);
    }
    // Sinónimos: peso menor, con su propio IDF
    const synSet = new Set();
    if (SYNONYMS[t]) for (const s of SYNONYMS[t]) synSet.add(s);
    if (SYNONYMS[st] && st !== t) for (const s of SYNONYMS[st]) synSet.add(s);
    for (const s of synSet) {
      for (const [v, w] of [[s, 2.6], [stem(s), 2.2], [s + 'S', 2.4], [s + 'ES', 2.4]]) {
        if (!variants.has(v) && unspscIndex[v]) variants.set(v, w * idf(v));
      }
    }

    // Por cada registro, solo cuenta la MEJOR variante de este token
    // (evita que sinónimos múltiples inflen el puntaje del mismo concepto)
    const bestPerIdx = new Map();
    for (const [v, weight] of variants) {
      for (const idx of unspscIndex[v]) {
        if (!bestPerIdx.has(idx) || weight > bestPerIdx.get(idx)) bestPerIdx.set(idx, weight);
      }
    }
    // subcadena sobre toda la base (revisión total) como respaldo
    if (st.length >= 4) {
      for (let idx = 0; idx < N; idx++) {
        if (unspscDB[idx].desc.includes(st)) {
          if (!bestPerIdx.has(idx)) bestPerIdx.set(idx, 1.2);
        }
      }
    }

    for (const [idx, w] of bestPerIdx) {
      scores.set(idx, (scores.get(idx) || 0) + w);
      if (!matchInfo.has(idx)) matchInfo.set(idx, new Set());
      matchInfo.get(idx).add(t);
    }
  }

  if (scores.size === 0) return [];

  // Raíces a verificar en la descripción por cada token de la consulta
  // (incluye sinónimos: ESMERIL también acepta AMOLADORA en la descripción)
  const descCheckRoots = baseTokens.map(t => {
    const roots = [stem(t)];
    const st0 = stem(t);
    if (SYNONYMS[t]) for (const s of SYNONYMS[t]) roots.push(stem(s));
    if (SYNONYMS[st0] && st0 !== t) for (const s of SYNONYMS[st0]) roots.push(stem(s));
    return roots.filter(r => r.length >= 3);
  });

  // Sustantivo principal + TODOS sus sinónimos con inflexiones
  const firstQ = baseTokens[0];
  const firstRoots = new Set([firstQ, firstQ + 'S', firstQ + 'ES']);
  const firstQst = stem(firstQ);
  firstRoots.add(firstQst);
  for (const src of [firstQ, firstQst]) {
    if (SYNONYMS[src]) for (const s of SYNONYMS[src]) {
      firstRoots.add(s); firstRoots.add(stem(s));
      firstRoots.add(s + 'S'); firstRoots.add(s + 'ES');
    }
  }
  const firstRootsArr = [...firstRoots].filter(r => r.length >= 3);

  let ranked = [...scores.entries()].map(([idx, sc]) => {
    // Multiplicador de cobertura: cuántos términos de la consulta cubre este registro.
    // Penaliza coincidencias de un solo término secundario
    // (ej. que "GALVANIZADO" domine sobre "NIPLE").
    const covered = matchInfo.has(idx) ? matchInfo.get(idx).size : 0;
    const coverage = covered / baseTokens.length;
    let score = sc * (0.35 + 0.65 * coverage);

    // BONUS: el sustantivo principal del producto coincide con el de la consulta
    // (vía sinónimos: LAPICERO → BOLIGRAFO, MOTOR → REDUCTOR)
    const descTokens = normalize(unspscDB[idx].desc).split(' ').filter(x => x.length > 2 && !STOPWORDS.has(x));
    const firstDescTok = descTokens[0] || '';
    const firstMatch = firstRootsArr.some(r => sameRoot(r, firstDescTok));
    
    // ¿ALGÚN token de la descripción hace match con ALGUNA raíz del primer token?
    const anyFirstInDesc = firstRootsArr.some(r => descTokens.some(dt => sameRoot(r, dt)));
    
    if (firstMatch) {
      score *= 3.0; // Primer sustantivo es el mismo: bonus fuerte
    } else if (anyFirstInDesc) {
      score *= 1.8; // El sustantivo principal aparece EN ALGUNA parte de la desc
    } else if (coverage >= 0.5) {
      score *= 0.7; // Buena cobertura pero sin sustantivo: categoría genérica
    } else {
      score *= 0.2; // Sin cobertura ni sustantivo principal: probablemente basura
    }

    // Bonus por relevancia en la DESCRIPCIÓN del producto:
    // un término (o su sinónimo) que aparece en el nombre del producto
    // vale más que uno que solo aparece en la clase o familia
    let descHits = 0;
    const d = unspscDB[idx].desc;
    for (const roots of descCheckRoots) {
      if (roots.some(r => d.includes(r))) descHits++;
    }
    score *= (1 + 0.15 * descHits);

    return { idx, sc: score, firstMatch, coverage };
  }).sort((a, b) => b.sc - a.sc);

  // Confianza según cobertura de tokens y posición relativa
  const top = ranked.slice(0, 3);
  const maxScore = top[0].sc;

  return top.map((r, i) => {
    const entry = unspscDB[r.idx];
    const covered = matchInfo.get(r.idx) ? matchInfo.get(r.idx).size : 0;
    const rel = r.sc / maxScore;

    let confidence;
    if (i === 0 && r.coverage >= 0.55 && r.firstMatch) confidence = 'ALTA';
    else if (r.coverage >= 0.5 || (r.firstMatch && rel > 0.65)) confidence = 'MEDIA';
    else confidence = 'BAJA';

    return {
      code: entry.code,
      desc: entry.desc,
      clase: entry.clase,
      familia: entry.familia,
      confidence,
      reason: `Coincidencia local: ${covered}/${baseTokens.length} términos${r.firstMatch ? ' · sustantivo principal' : ''}`
    };
  });
}

let API_KEY = '';
try { API_KEY = localStorage.getItem('anthropic_api_key') || ''; } catch(e) {}

function saveApiKey() {
  const v = document.getElementById('apiKeyInput').value.trim();
  if (!v) { showToast('⚠ Ingresa una API key válida', 'warn'); return; }
  API_KEY = v;
  try { localStorage.setItem('anthropic_api_key', v); } catch(e) {}
  updateApiStatus();
  showToast('✅ API key guardada en este navegador', 'ok');
}

function updateApiStatus() {
  const pill = document.getElementById('apiStatusPill');
  const card = document.getElementById('apiCard');
  if (API_KEY) {
    pill.textContent = 'Configurada';
    pill.classList.add('ok');
    card.classList.add('ok');
    document.getElementById('apiKeyInput').value = API_KEY;
  } else {
    pill.textContent = 'Sin configurar';
    pill.classList.remove('ok');
    card.classList.remove('ok');
  }
}

function requireApiKey() {
  if (IN_CLAUDE) return true; // dentro de Claude.ai la API va por la plataforma
  if (!API_KEY) {
    showToast('🔑 Configura primero tu API Key de Anthropic (panel superior)', 'warn');
    document.getElementById('apiKeyInput').focus();
    document.getElementById('apiCard').scrollIntoView({ behavior:'smooth', block:'center' });
    return false;
  }
  return true;
}

async function callClaude(items) {
  let userPrompt = 'Clasifica los siguientes materiales. Para cada uno, elige ÚNICAMENTE entre sus candidatos listados (formato: CODIGO | PRODUCTO | CLASE).\n\n';
  for (const item of items) {
    userPrompt += `=== MATERIAL id=${item.id} ===\nDENOMINACION: ${item.denominacion}\nCANDIDATOS UNSPSC:\n`;
    for (const c of item.candidates) {
      userPrompt += `${c.code} | ${c.desc} | ${c.clase}\n`;
    }
    userPrompt += '\n';
  }
  userPrompt += 'Responde solo el JSON.';

  let res;
  try {
    res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: IN_CLAUDE
        ? { 'Content-Type': 'application/json' }
        : {
            'Content-Type': 'application/json',
            'x-api-key': API_KEY,
            'anthropic-version': '2023-06-01',
            'anthropic-dangerous-direct-browser-access': 'true'
          },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1500,
        system: SYSTEM_PROMPT,
        messages: [{ role: 'user', content: userPrompt }]
      })
    });
  } catch (e) {
    throw new Error('No se pudo conectar con api.anthropic.com. Verifica tu conexión a internet o si un firewall/proxy corporativo bloquea la solicitud.');
  }

  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    const msg = err.error?.message || '';
    if (res.status === 401) throw new Error(IN_CLAUDE ? 'Error de autenticación con la plataforma Claude. Reintenta en unos segundos.' : 'API key inválida o expirada. Verifícala en el panel superior.');
    if (res.status === 429) throw new Error('Límite de uso de la API alcanzado. Espera unos segundos y reintenta.');
    if (res.status === 400 && msg.includes('credit')) throw new Error('Tu cuenta de Anthropic no tiene créditos disponibles.');
    throw new Error(msg || 'HTTP ' + res.status);
  }

  const data = await res.json();
  const text = (data.content || []).filter(b => b.type === 'text').map(b => b.text).join('');
  const clean = text.replace(/```json|```/g, '').trim();
  const parsed = JSON.parse(clean);
  return parsed.results || [];
}

function validateMatches(matches, candidateMap) {
  return (matches || [])
    .filter(m => candidateMap.has(m.code))
    .map(m => {
      const c = candidateMap.get(m.code);
      return {
        code: m.code,
        desc: c.desc,
        clase: c.clase,
        familia: c.familia,
        confidence: ['ALTA','MEDIA','BAJA'].includes(m.confidence) ? m.confidence : 'BAJA',
        reason: m.reason || ''
      };
    });
}

/* ═══════════════════════════════════════════════════════════════════════════
   CONSULTA INDIVIDUAL
═══════════════════════════════════════════════════════════════════════════ */
async function searchSingle() {
  const denom = document.getElementById('singleInput').value.trim().toUpperCase();
  if (!denom) { showToast('⚠ Ingresa una denominación', 'warn'); return; }
  if (ENGINE === 'ia' && !requireApiKey()) return;

  const btn = document.getElementById('btnSingle');
  btn.disabled = true;
  document.getElementById('btnSingleIcon').innerHTML = '<span class="spinner"></span>';
  document.getElementById('singleResult').innerHTML =
    '<div style="text-align:center; padding:30px; color:var(--text-mute); font-size:13px;">Revisando los ' +
    unspscDB.length.toLocaleString('es') + ' códigos de la base para «' + esc(denom) + '»…</div>';

  try {
    let matches;
    if (ENGINE === 'local') {
      matches = localClassify(denom);
    } else {
      const candidates = getCandidates(denom);
      const candidateMap = new Map(candidates.map(c => [c.code, c]));
      const results = await callClaude([{ id: 0, denominacion: denom, candidates }]);
      matches = validateMatches(results[0]?.matches, candidateMap);
    }

    if (matches.length === 0) {
      document.getElementById('singleResult').innerHTML =
        '<div style="text-align:center; padding:30px; color:var(--warning); font-size:13px;">No se encontró una coincidencia adecuada en la base para este material.</div>';
    } else {
      let html = '';
      matches.forEach((m, i) => {
        html += `<div class="match-card ${i === 0 ? 'top' : ''}">
          <div class="match-rank">${i + 1}</div>
          <div class="match-body">
            <div class="match-code">${esc(m.code)}</div>
            <div class="match-desc">${esc(m.desc)}</div>
            <div class="match-hier">${esc(m.familia)} → ${esc(m.clase)}</div>
            ${m.reason ? `<div class="match-reason">💡 ${esc(m.reason)}</div>` : ''}
          </div>
          <span class="conf ${m.confidence}">${m.confidence}</span>
        </div>`;
      });
      document.getElementById('singleResult').innerHTML = html;
    }
  } catch (e) {
    showToast('❌ Error: ' + e.message, 'err');
    document.getElementById('singleResult').innerHTML = '';
  } finally {
    btn.disabled = false;
    document.getElementById('btnSingleIcon').textContent = '🔍';
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   CONSULTA MASIVA
═══════════════════════════════════════════════════════════════════════════ */
(function setupDZ() {
  const dz = document.getElementById('dzBulk');
  const input = document.getElementById('fileBulk');
  ['dragover','dragenter'].forEach(e => dz.addEventListener(e, ev => { ev.preventDefault(); dz.classList.add('over'); }));
  ['dragleave','drop'].forEach(e => dz.addEventListener(e, ev => { ev.preventDefault(); dz.classList.remove('over'); }));
  dz.addEventListener('drop', ev => loadBulkFile(ev.dataTransfer.files[0]));
  input.addEventListener('change', () => loadBulkFile(input.files[0]));
})();

async function loadBulkFile(file) {
  if (!file) return;
  try {
    let rows;
    if (/\.(xlsx|xls)$/i.test(file.name)) {
      const data = await file.arrayBuffer();
      const wb = XLSX.read(data, { type: 'array' });
      rows = [];
      wb.SheetNames.forEach(name => {
        rows = rows.concat(XLSX.utils.sheet_to_json(wb.Sheets[name], { header: 1, defval: '' }));
      });
    } else {
      const text = await file.text();
      const sep = text.includes('\t') ? '\t' : (text.includes(';') ? ';' : ',');
      rows = text.split(/\r?\n/).map(l => l.split(sep));
    }
    const lines = rows
      .filter(r => r && r.some(c => String(c).trim()))
      .map(r => `${String(r[0] ?? '').trim()}\t${String(r[1] ?? '').trim()}`);
    document.getElementById('bulkInput').value = lines.join('\n');
    showToast('✅ ' + lines.length + ' filas cargadas desde ' + file.name, 'ok');
  } catch (e) {
    showToast('❌ Error al leer archivo: ' + e.message, 'err');
  }
}

function parseBulkInput() {
  const raw = document.getElementById('bulkInput').value.trim();
  if (!raw) return [];
  const items = [];
  for (const line of raw.split('\n')) {
    if (!line.trim()) continue;
    let sap = '', denom = '';
    if (line.includes('\t')) {
      const parts = line.split('\t');
      sap = parts[0].trim();
      denom = parts.slice(1).join(' ').trim();
    } else {
      const m = line.trim().match(/^(\d{6,12})\s+(.+)$/);
      if (m) { sap = m[1]; denom = m[2]; }
      else denom = line.trim();
    }
    if (denom) items.push({ sap, denom: denom.toUpperCase() });
  }
  return items;
}

const BATCH_SIZE = 5;

async function processBulk() {
  const items = parseBulkInput();
  if (items.length === 0) { showToast('⚠ Ingresa o carga los materiales a clasificar', 'warn'); return; }
  if (ENGINE === 'ia' && !requireApiKey()) return;

  const btn = document.getElementById('btnBulk');
  btn.disabled = true;
  document.getElementById('btnBulkIcon').innerHTML = '<span class="spinner"></span>';

  bulkResults = items.map(it => ({ ...it, matches: [], error: null }));

  const pBox = document.getElementById('progressBox');
  const pFill = document.getElementById('progressFill');
  const pCount = document.getElementById('progressCount');
  const pDetail = document.getElementById('progressDetail');
  pBox.classList.add('show');
  document.getElementById('resultsCard').classList.remove('show');

  let processed = 0;
  pCount.textContent = `0 / ${items.length}`;
  pFill.style.width = '0%';

  // ── MODO LOCAL: procesamiento instantáneo sin API ──
  if (ENGINE === 'local') {
    for (let i = 0; i < items.length; i++) {
      bulkResults[i].matches = localClassify(items[i].denom);
      if (i % 10 === 0 || i === items.length - 1) {
        pCount.textContent = `${i + 1} / ${items.length}`;
        pFill.style.width = ((i + 1) / items.length * 100) + '%';
        pDetail.textContent = '▸ ' + items[i].denom.slice(0, 50);
        await new Promise(r => setTimeout(r, 0)); // permitir refresco de UI
      }
    }
    pDetail.textContent = '✓ Procesamiento completado (motor local, sin costo)';
    renderBulkResults();
    btn.disabled = false;
    document.getElementById('btnBulkIcon').textContent = '⚡';
    setTimeout(() => pBox.classList.remove('show'), 1500);
    showToast('✅ ' + items.length + ' materiales clasificados (motor local)', 'ok');
    return;
  }

  // ── MODO IA: por lotes vía Claude API ──
  for (let start = 0; start < items.length; start += BATCH_SIZE) {
    const batch = items.slice(start, start + BATCH_SIZE);
    pDetail.textContent = '▸ ' + batch.map(b => b.denom.slice(0, 40)).join('  ·  ');

    const payload = batch.map((it, i) => ({
      id: start + i,
      denominacion: it.denom,
      candidates: getCandidates(it.denom, 35)
    }));
    const candidateMaps = payload.map(p => new Map(p.candidates.map(c => [c.code, c])));

    try {
      const results = await callClaude(payload);
      for (const r of results) {
        const localIdx = r.id - start;
        if (localIdx >= 0 && localIdx < batch.length) {
          bulkResults[r.id].matches = validateMatches(r.matches, candidateMaps[localIdx]);
        }
      }
    } catch (e) {
      for (let i = 0; i < batch.length; i++) {
        const gid = start + i;
        try {
          const single = await callClaude([{ id: gid, denominacion: batch[i].denom, candidates: payload[i].candidates }]);
          bulkResults[gid].matches = validateMatches(single[0]?.matches, candidateMaps[i]);
        } catch (e2) {
          bulkResults[gid].error = e2.message;
        }
      }
    }

    processed = Math.min(start + BATCH_SIZE, items.length);
    pCount.textContent = `${processed} / ${items.length}`;
    pFill.style.width = (processed / items.length * 100) + '%';
  }

  pDetail.textContent = '✓ Procesamiento completado';
  renderBulkResults();

  btn.disabled = false;
  document.getElementById('btnBulkIcon').textContent = '⚡';
  setTimeout(() => pBox.classList.remove('show'), 1500);
  showToast('✅ ' + items.length + ' materiales clasificados', 'ok');
}

function renderBulkResults() {
  const tbody = document.getElementById('resultsBody');
  let html = '';

  for (const r of bulkResults) {
    const best = r.matches[0];
    const alts = r.matches.slice(1);

    html += '<tr>';
    html += `<td class="td-sap">${r.sap ? esc(r.sap) : '<span class="no-sap">—</span>'}</td>`;
    html += `<td class="td-den">${esc(r.denom)}</td>`;

    if (r.error) {
      html += `<td colspan="4" class="err-cell">⚠ Error: ${esc(r.error)}</td>`;
    } else if (!best) {
      html += `<td colspan="4" class="err-cell" style="color:var(--warning);">Sin coincidencia adecuada en la base</td>`;
    } else {
      html += `<td class="td-code">${esc(best.code)}</td>`;
      html += `<td class="td-desc">${esc(best.desc)}</td>`;
      html += `<td><span class="conf ${best.confidence}">${best.confidence}</span></td>`;
      html += `<td class="td-alt">${
        alts.length
          ? alts.map(a => `<span><b>${esc(a.code)}</b> · ${esc(a.desc.slice(0, 32))}${a.desc.length > 32 ? '…' : ''}</span>`).join('')
          : '<span style="color:var(--text-mute);">—</span>'
      }</td>`;
    }
    html += '</tr>';
  }

  tbody.innerHTML = html;
  document.getElementById('resultsCount').innerHTML =
    `<b>${bulkResults.length}</b> materiales · ` +
    `<span style="color:var(--success);">${bulkResults.filter(r => r.matches[0]?.confidence === 'ALTA').length} ALTA</span> · ` +
    `<span style="color:var(--warning);">${bulkResults.filter(r => r.matches[0]?.confidence === 'MEDIA').length} MEDIA</span> · ` +
    `<span style="color:var(--danger);">${bulkResults.filter(r => !r.matches[0] || r.matches[0].confidence === 'BAJA').length} BAJA/sin match</span>`;
  document.getElementById('resultsCard').classList.add('show');
  document.getElementById('resultsCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function clearBulk() {
  document.getElementById('bulkInput').value = '';
  document.getElementById('fileBulk').value = '';
  bulkResults = [];
  document.getElementById('resultsCard').classList.remove('show');
  document.getElementById('progressBox').classList.remove('show');
}

/* ═══════════════════════════════════════════════════════════════════════════
   EXPORTACIÓN
═══════════════════════════════════════════════════════════════════════════ */
function exportXLSX() {
  if (bulkResults.length === 0) return;
  const rows = [['CODIGO SAP','DENOMINACION','CODIGO UNSPSC','DESCRIPCION UNSPSC','CONFIANZA','ALTERNATIVA 2','ALTERNATIVA 3']];
  for (const r of bulkResults) {
    const b = r.matches[0] || {};
    const a2 = r.matches[1], a3 = r.matches[2];
    rows.push([
      r.sap || '',
      r.denom,
      b.code || '',
      b.desc || (r.error ? 'ERROR: ' + r.error : 'SIN COINCIDENCIA'),
      b.confidence || '',
      a2 ? a2.code + ' - ' + a2.desc : '',
      a3 ? a3.code + ' - ' + a3.desc : ''
    ]);
  }
  const ws = XLSX.utils.aoa_to_sheet(rows);
  ws['!cols'] = [{wch:12},{wch:45},{wch:14},{wch:45},{wch:10},{wch:40},{wch:40}];
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Clasificacion UNSPSC');
  XLSX.writeFile(wb, 'clasificacion_unspsc.xlsx');
  showToast('⬇ Excel exportado: clasificacion_unspsc.xlsx', 'ok');
}

function copyTSV() {
  if (bulkResults.length === 0) return;
  const lines = ['CODIGO SAP\tDENOMINACION\tCODIGO UNSPSC\tDESCRIPCION UNSPSC\tCONFIANZA'];
  for (const r of bulkResults) {
    const b = r.matches[0] || {};
    lines.push([r.sap || '', r.denom, b.code || '', b.desc || '', b.confidence || ''].join('\t'));
  }
  navigator.clipboard.writeText(lines.join('\n'))
    .then(() => showToast('📋 Copiado — pega directamente en Excel', 'ok'));
}

/* ═══ UI ═══ */
document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById(tab.dataset.panel).classList.add('active');
  });
});

function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

let toastTimer;
function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + (type || '') + ' show';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
}

/* ═══ Inicialización ═══ */
try {
  buildIndex();
} catch (e) {
  document.getElementById('dbStatusText').textContent = 'Error al cargar base: ' + e.message;
}
updateApiStatus();
setEngine(ENGINE);
document.getElementById('apiKeyInput').addEventListener('keydown', e => { if (e.key === 'Enter') saveApiKey(); });
</script>
