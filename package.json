let unspscDB = [];      // [{code, desc, clase, familia}]
let unspscIndex = {};   // token -> array de idx
let bulkResults = [];

/* ═══ Indexado completo (se ejecuta al final del script) ═══ */
function buildIndex() {
  const clases = UNSPSC_RAW.c.map(s => {
    const i = s.indexOf('|');
    return { clase: s.slice(0, i), familia: s.slice(i + 1) };
  });

  for (const rec of UNSPSC_RAW.p) {
    const a = rec.indexOf('|');
    const b = rec.lastIndexOf('|');
    const code = rec.slice(0, a);
    const desc = rec.slice(a + 1, b);
    const ci = parseInt(rec.slice(b + 1), 10);
    const idx = unspscDB.length;
    const entry = { code, desc, clase: clases[ci].clase, familia: clases[ci].familia };
    unspscDB.push(entry);

    // Indexar TODOS los niveles: producto + clase + familia (revisión total)
    const allTokens = new Set([
      ...tokenize(desc),
      ...tokenize(entry.clase),
      ...tokenize(entry.familia)
    ]);
    for (const t of allTokens) {
      if (!unspscIndex[t]) unspscIndex[t] = [];
      unspscIndex[t].push(idx);
    }
  }

  document.getElementById('dbStatusText').innerHTML =
    'Base precargada · <b>' + unspscDB.length.toLocaleString('es') + '</b> códigos UNSPSC';
}

